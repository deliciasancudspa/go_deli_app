{
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/web.html" },
    { "src": "/aliados", "dest": "/aliados.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/web", "dest": "/web.html" },
    { "src": "/tienda", "dest": "/tienda.html" },
    { "src": "/([^/.]+)", "dest": "/tienda.html?slug=$1" }
  ]
}
